# nginx_security.conf.sample — Hardening untuk SIDIX VPS
# ========================================================
# Letakkan di /etc/nginx/conf.d/ atau include di server block per domain.
# Test: nginx -t, lalu nginx -s reload.

# ── Rate Limit Zones (global, define di http block) ─────────────────────────
limit_req_zone $binary_remote_addr zone=sidix_general:10m rate=30r/m;
limit_req_zone $binary_remote_addr zone=sidix_chat:10m rate=20r/m;
limit_req_zone $binary_remote_addr zone=sidix_login:10m rate=5r/m;
limit_conn_zone $binary_remote_addr zone=sidix_conn:10m;

# ── Block bad bots/scanners ─────────────────────────────────────────────────
map $http_user_agent $sidix_bad_bot {
    default 0;
    ~*sqlmap         1;
    ~*nikto          1;
    ~*nmap           1;
    ~*masscan        1;
    ~*nuclei         1;
    ~*dirbuster      1;
    ~*gobuster       1;
    ~*ffuf           1;
    ~*wpscan         1;
    ~*acunetix       1;
    ~*havij          1;
    ~*burpsuite      1;
    ~*"go-http-client" 1;
    "" 1;   # empty UA
}

# ── Block suspicious paths ──────────────────────────────────────────────────
map $request_uri $sidix_bad_path {
    default 0;
    ~*\.env$              1;
    ~*\.git/              1;
    ~*wp-admin            1;
    ~*wp-login            1;
    ~*phpmyadmin          1;
    ~*\.php$              1;
    ~*\.aspx?$            1;
    ~*\.jsp$              1;
    ~*/admin\.[a-z]+$     1;
    ~*/setup\.php         1;
    ~*/install\.php       1;
    ~*\.aws/              1;
    ~*\.ssh/              1;
    ~*/etc/passwd         1;
    ~*\.\./\.\./          1;
    ~*%2e%2e%2f           1;
}

# ── Server block (per domain) ───────────────────────────────────────────────
server {
    listen 443 ssl http2;
    server_name app.sidixlab.com;

    # ── TLS hardening ──
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5:!RC4:!DH;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # ── Security Headers ──
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), camera=(), microphone=(self), payment=()" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://*.sidixlab.com wss://*.sidixlab.com" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # ── HIDE backend identity ──
    server_tokens off;
    more_clear_headers "Server" "X-Powered-By" "X-AspNet-Version";

    # ── Limit request body (anti-DOS) ──
    client_max_body_size 10M;
    client_body_timeout 30s;
    client_header_timeout 10s;

    # ── Block bad bots ──
    if ($sidix_bad_bot) {
        return 403;
    }

    # ── Block suspicious paths ──
    if ($sidix_bad_path) {
        return 444;   # close connection silently
    }

    # ── Connection limit ──
    limit_conn sidix_conn 20;

    # ── Default rate limit ──
    limit_req zone=sidix_general burst=10 nodelay;

    # ── Heavier limit untuk endpoint sensitif ──
    location /agent/chat {
        limit_req zone=sidix_chat burst=5 nodelay;
        proxy_pass http://127.0.0.1:8765;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 120s;
    }

    location /sidix/grow {
        limit_req zone=sidix_chat burst=2 nodelay;
        proxy_pass http://127.0.0.1:8765;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 300s;
    }

    location ~* /(login|signup|auth) {
        limit_req zone=sidix_login burst=3 nodelay;
        proxy_pass http://127.0.0.1:8765;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # ── Default proxy ──
    location / {
        proxy_pass http://127.0.0.1:4000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ── Logging untuk audit ──
    access_log /var/log/nginx/sidix_access.log combined;
    error_log /var/log/nginx/sidix_error.log warn;
}

# ── Fail2ban Jail (file: /etc/fail2ban/jail.d/sidix.local) ─────────────────
# [sidix-blocked]
# enabled  = true
# filter   = sidix-blocked
# logpath  = /var/log/nginx/sidix_access.log
# action   = iptables-multiport[name=sidix, port="80,443", protocol=tcp]
# maxretry = 5
# findtime = 600
# bantime  = 86400

# ── Fail2ban Filter (file: /etc/fail2ban/filter.d/sidix-blocked.conf) ──────
# [Definition]
# failregex = ^<HOST> .* "(GET|POST|PUT|DELETE) .*HTTP.*" (403|444|429)
# ignoreregex =
