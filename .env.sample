# ============================================================
# SIDIX — Environment Variable Template
# cp .env.sample .env   →   isi nilai di .env
# JANGAN commit .env ke Git!
# ============================================================

# ------------------------------------------------------------
# Deploy mode (untuk Docker Compose / VPS)
# ------------------------------------------------------------
DOMAIN=sidixlab.com
VITE_BRAIN_QA_URL=https://sidixlab.com/api

# ------------------------------------------------------------
# SIDIX Inference Engine
# ------------------------------------------------------------
SIDIX_USE_MOCK_LLM=0
BRAIN_QA_HOST=0.0.0.0
BRAIN_QA_PORT=8765

# ------------------------------------------------------------
# LoRA Inference (v1 — Qwen2.5-7B + SIDIX adapter)
# ------------------------------------------------------------
# Set ke 0 untuk aktifkan 4-bit quantization (butuh bitsandbytes + CUDA)
# Set ke 1 jika bitsandbytes tidak support (Windows tanpa CUDA/WSL)
SIDIX_DISABLE_4BIT=0

# Model mode: "local_lora" untuk pakai adapter, "mock" untuk testing tanpa GPU
BRAIN_QA_MODEL_MODE=local_lora

# HuggingFace token (opsional, anjuran untuk avoid rate limit saat download base model)
# Buat di https://huggingface.co/settings/tokens
HF_TOKEN=

# ------------------------------------------------------------
# Admin & Rate Limit
# ------------------------------------------------------------
BRAIN_QA_ADMIN_TOKEN=
BRAIN_QA_RATE_LIMIT_RPM=60
BRAIN_QA_ANON_DAILY_CAP=100

# ------------------------------------------------------------
# SIDIX User UI (Vite)
# ------------------------------------------------------------
VITE_BRAIN_QA_URL=http://localhost:8765

# ------------------------------------------------------------
# Optional: Image generation (G2 pipeline)
# ------------------------------------------------------------
IMAGE_GEN_ENABLED=0
IMAGE_GEN_MODEL=stub
IMAGE_GEN_MAX_CONCURRENT=3

# ------------------------------------------------------------
# Optional: Vision (G3 pipeline)
# ------------------------------------------------------------
VISION_ENABLED=0
VISION_MODEL=stub

# ------------------------------------------------------------
# CI/Testing
# ------------------------------------------------------------
# Override untuk CI: set SIDIX_USE_MOCK_LLM=1 agar tidak butuh GPU
COVERAGE_MIN_PERCENT=40
